{
  "name": "@wildmat/personality",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Thin Cloudflare Worker proxy for personality.wildmat.dev. Engine lives at ~/Github/personality.",
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0 --port 8788",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "typescript": "^5.5.3",
    "vitest": "^2.1.0",
    "wrangler": "^4.0.0"
  }
}
